// Auction Marketplace - Prisma Schema
generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum Role {
  BUYER
  SELLER
  ADMIN
}

enum AuctionStatus {
  UPCOMING
  LIVE
  ENDED
  COMPLETED
  CANCELLED
}

enum TransactionStatus {
  PENDING
  PAID
  IN_ESCROW
  RELEASED
  REFUNDED
  DISPUTED
}

enum NotificationType {
  OUTBID
  AUCTION_ENDING_SOON
  AUCTION_WON
  PAYMENT_REQUIRED
  PAYMENT_RECEIVED
  BID_PLACED
  AUCTION_ENDED
  LISTING_APPROVED
  LISTING_REJECTED
  ITEM_SHIPPED
  ITEM_DELIVERED
  GENERAL
}

model User {
  id            String    @id @default(uuid())
  email         String    @unique
  passwordHash  String?   @map("password_hash")
  name          String
  avatar        String?
  role          Role      @default(BUYER)
  emailVerified Boolean   @default(false) @map("email_verified")
  googleId      String?   @unique @map("google_id")
  suspended     Boolean   @default(false)
  createdAt     DateTime  @default(now()) @map("created_at")
  updatedAt     DateTime  @updatedAt @map("updated_at")

  buyerProfile   Buyer?
  sellerProfile  Seller?
  reviewsGiven   Review[] @relation("Reviewer")
  reviewsReceived Review[] @relation("Reviewee")
  notifications  Notification[]
  watchlist      WatchlistItem[]
  refreshTokens  RefreshToken[]
  savedSearches  SavedSearch[]
  priceAlerts    PriceAlert[]
  recentlyViewed RecentlyViewed[]
}

model RefreshToken {
  id        String   @id @default(uuid())
  token     String   @unique
  userId    String   @map("user_id")
  expiresAt DateTime @map("expires_at")
  createdAt DateTime @default(now()) @map("created_at")
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model Buyer {
  id        String   @id @default(uuid())
  userId    String   @unique @map("user_id")
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")
  bids      Bid[]
  orders    Order[]
  payments  Payment[]
}

model Seller {
  id            String   @id @default(uuid())
  userId        String   @unique @map("user_id")
  user          User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  verified      Boolean  @default(false)
  kycVerified   Boolean  @default(false) @map("kyc_verified")
  stripeAccountId String? @map("stripe_account_id")
  createdAt     DateTime @default(now()) @map("created_at")
  updatedAt     DateTime @updatedAt @map("updated_at")
  auctions      Auction[]
  orders        Order[]
}

model Category {
  id          String    @id @default(uuid())
  name        String
  slug        String    @unique
  description String?
  imageUrl    String?   @map("image_url")
  auctions    Auction[]
}

model Auction {
  id                String        @id @default(uuid())
  sellerId          String        @map("seller_id")
  categoryId        String?       @map("category_id")
  title             String
  description       String
  startingBid       Decimal       @map("starting_bid") @db.Decimal(12, 2)
  currentBid        Decimal       @map("current_bid") @db.Decimal(12, 2)
  reservePrice      Decimal?      @map("reserve_price") @db.Decimal(12, 2)
  minIncrement      Decimal       @default(100) @map("min_increment") @db.Decimal(12, 2)
  startTime         DateTime      @map("start_time")
  endTime           DateTime      @map("end_time")
  status            AuctionStatus @default(UPCOMING)
  approved          Boolean       @default(false)
  featured          Boolean       @default(false)
  antiSnipingMinutes Int          @default(5) @map("anti_sniping_minutes")
  viewCount         Int          @default(0) @map("view_count")
  draft             Boolean      @default(false)
  createdAt         DateTime      @default(now()) @map("created_at")
  updatedAt         DateTime      @updatedAt @map("updated_at")

  seller   Seller   @relation(fields: [sellerId], references: [id], onDelete: Cascade)
  category Category? @relation(fields: [categoryId], references: [id])
  images   ProductImage[]
  bids     Bid[]
  orders   Order[]
  watchlist WatchlistItem[]
  featuredListing FeaturedListing?
  priceAlerts     PriceAlert[]
  recentlyViewed  RecentlyViewed[]
}

model ProductImage {
  id        String   @id @default(uuid())
  auctionId String   @map("auction_id")
  url       String
  order     Int      @default(0)
  createdAt DateTime @default(now()) @map("created_at")
  auction   Auction  @relation(fields: [auctionId], references: [id], onDelete: Cascade)
}

model Bid {
  id        String   @id @default(uuid())
  auctionId String   @map("auction_id")
  buyerId   String   @map("buyer_id")
  amount    Decimal  @db.Decimal(12, 2)
  isAutoBid Boolean  @default(false) @map("is_auto_bid")
  maxAutoBid Decimal? @map("max_auto_bid") @db.Decimal(12, 2)
  createdAt DateTime @default(now()) @map("created_at")

  auction Auction @relation(fields: [auctionId], references: [id], onDelete: Cascade)
  buyer   Buyer   @relation(fields: [buyerId], references: [id], onDelete: Cascade)

  @@index([auctionId])
  @@index([buyerId])
}

model AutoBid {
  id         String   @id @default(uuid())
  auctionId  String   @map("auction_id")
  buyerId    String   @map("buyer_id")
  maxAmount  Decimal  @map("max_amount") @db.Decimal(12, 2)
  createdAt  DateTime @default(now()) @map("created_at")
  updatedAt  DateTime @updatedAt @map("updated_at")

  @@unique([auctionId, buyerId])
  @@index([auctionId])
}

model Order {
  id              String            @id @default(uuid())
  auctionId       String            @map("auction_id")
  buyerId         String            @map("buyer_id")
  sellerId        String            @map("seller_id")
  winningBidId    String?           @map("winning_bid_id")
  amount          Decimal           @db.Decimal(12, 2)
  platformFee     Decimal           @map("platform_fee") @db.Decimal(12, 2)
  sellerAmount    Decimal           @map("seller_amount") @db.Decimal(12, 2)
  status          TransactionStatus @default(PENDING)
  paidAt          DateTime?         @map("paid_at")
  shippedAt       DateTime?         @map("shipped_at")
  deliveredAt     DateTime?         @map("delivered_at")
  stripePaymentIntentId String?     @map("stripe_payment_intent_id")
  stripeTransferId String?          @map("stripe_transfer_id")
  createdAt       DateTime          @default(now()) @map("created_at")
  updatedAt       DateTime          @updatedAt @map("updated_at")

  auction Auction  @relation(fields: [auctionId], references: [id])
  buyer   Buyer    @relation(fields: [buyerId], references: [id])
  seller  Seller   @relation(fields: [sellerId], references: [id])
  payment Payment?
}

model Payment {
  id            String   @id @default(uuid())
  orderId      String   @unique @map("order_id")
  buyerId      String   @map("buyer_id")
  amount       Decimal  @db.Decimal(12, 2)
  stripePaymentIntentId String? @map("stripe_payment_intent_id")
  status       String
  createdAt    DateTime @default(now()) @map("created_at")
  updatedAt    DateTime @updatedAt @map("updated_at")

  order Order  @relation(fields: [orderId], references: [id])
  buyer Buyer  @relation(fields: [buyerId], references: [id])
}

model Review {
  id        String   @id @default(uuid())
  orderId   String   @map("order_id")
  reviewerId String  @map("reviewer_id")
  revieweeId String @map("reviewee_id")
  rating    Int
  comment   String?
  createdAt DateTime @default(now()) @map("created_at")

  reviewer User @relation("Reviewer", fields: [reviewerId], references: [id])
  reviewee User @relation("Reviewee", fields: [revieweeId], references: [id])

  @@unique([orderId, reviewerId])
}

model Transaction {
  id          String   @id @default(uuid())
  orderId     String   @map("order_id")
  type        String
  amount      Decimal  @db.Decimal(12, 2)
  stripeId    String?  @map("stripe_id")
  metadata    Json?
  createdAt   DateTime @default(now()) @map("created_at")
}

model FeaturedListing {
  id        String   @id @default(uuid())
  auctionId String   @unique @map("auction_id")
  startAt   DateTime @map("start_at")
  endAt     DateTime @map("end_at")
  priority  Int      @default(0)
  createdAt DateTime @default(now()) @map("created_at")
  auction   Auction  @relation(fields: [auctionId], references: [id], onDelete: Cascade)
}

model Notification {
  id        String           @id @default(uuid())
  userId    String           @map("user_id")
  type      NotificationType
  title     String
  body      String?
  read      Boolean          @default(false)
  link      String?
  metadata  Json?
  createdAt DateTime         @default(now()) @map("created_at")
  user      User             @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
}

model WatchlistItem {
  id        String   @id @default(uuid())
  userId    String   @map("user_id")
  auctionId String   @map("auction_id")
  createdAt DateTime @default(now()) @map("created_at")
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  auction   Auction  @relation(fields: [auctionId], references: [id], onDelete: Cascade)

  @@unique([userId, auctionId])
  @@index([userId])
}

model Dispute {
  id          String   @id @default(uuid())
  orderId     String   @map("order_id")
  raisedBy    String   @map("raised_by")
  reason      String
  description String?
  status      String   @default("OPEN")
  resolution  String?
  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @updatedAt @map("updated_at")
}

model EmailVerification {
  id        String   @id @default(uuid())
  email     String
  token     String   @unique
  expiresAt DateTime @map("expires_at")
  createdAt DateTime @default(now()) @map("created_at")
}

model PasswordReset {
  id        String   @id @default(uuid())
  email     String
  token     String   @unique
  expiresAt DateTime @map("expires_at")
  createdAt DateTime @default(now()) @map("created_at")
}

model SavedSearch {
  id        String   @id @default(uuid())
  userId    String   @map("user_id")
  query     String
  filters   Json?
  createdAt DateTime @default(now()) @map("created_at")
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
}

model PriceAlert {
  id        String   @id @default(uuid())
  userId    String   @map("user_id")
  auctionId String   @map("auction_id")
  maxPrice  Decimal  @map("max_price") @db.Decimal(12, 2)
  notified  Boolean  @default(false)
  createdAt DateTime @default(now()) @map("created_at")
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  auction   Auction  @relation(fields: [auctionId], references: [id], onDelete: Cascade)

  @@unique([userId, auctionId])
  @@index([auctionId])
}

model RecentlyViewed {
  id        String   @id @default(uuid())
  userId    String   @map("user_id")
  auctionId String   @map("auction_id")
  viewedAt  DateTime @default(now()) @map("viewed_at")
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  auction   Auction  @relation(fields: [auctionId], references: [id], onDelete: Cascade)

  @@unique([userId, auctionId])
  @@index([userId])
}
