# Production env for VPS at /var/www/auction-marketplace
# Copy to backend/.env and fill in values.
#
# Ports (must match cloudflared tunnel and ecosystem.config.cjs):
#   Backend:  5020
#   Frontend: 3020

# Database (use a dedicated DB user and strong password)
DATABASE_URL="postgresql://auction:PASSWORD@localhost:5432/auction_db"

# Auth
JWT_SECRET="generate-a-long-random-secret-at-least-32-characters"
JWT_EXPIRES_IN="7d"
GOOGLE_CLIENT_ID=""
GOOGLE_CLIENT_SECRET=""
GOOGLE_CALLBACK_URL="https://api.auction.bfcpos.com/api/auth/google/callback"

# Stripe
STRIPE_SECRET_KEY="sk_live_..."
STRIPE_WEBHOOK_SECRET="whsec_..."
STRIPE_PUBLISHABLE_KEY="pk_live_..."

# AWS S3 (optional, for product images)
AWS_ACCESS_KEY_ID=""
AWS_SECRET_ACCESS_KEY=""
AWS_REGION="us-east-1"
AWS_S3_BUCKET="auction-marketplace-images"

# Public URLs (replace with your cloudflared hostnames)
FRONTEND_URL="https://auction.bfcpos.com"
BACKEND_URL="https://api.auction.bfcpos.com"
PLATFORM_FEE_PERCENT=0.5

# Frontend build + runtime (NEXT_PUBLIC_* are baked into the client bundle at build time)
NEXT_PUBLIC_API_URL="https://api.auction.bfcpos.com"
NEXT_PUBLIC_SOCKET_URL="https://api.auction.bfcpos.com"
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY="pk_live_..."
NEXT_PUBLIC_GOOGLE_CLIENT_ID=""
